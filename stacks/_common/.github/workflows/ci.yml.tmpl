# CI/CD Pipeline
# Generated by scaffolding.tool - do not edit manually
# 2-job split: build on builds VM, deploy on projects VM

name: CI/CD

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

concurrency:
  group: ${{ github.workflow }}-${{ github.ref }}
  cancel-in-progress: true

env:
  REGISTRY: ghcr.io
  FORCE_JAVASCRIPT_ACTIONS_TO_NODE24: true

jobs:
  build:
    name: Build & Push Image
    runs-on: [self-hosted, builds]
    timeout-minutes: 30
    permissions:
      contents: read
      packages: write

    steps:
      - name: Checkout
        uses: actions/checkout@v6

      - name: Log in to GHCR
        if: ${{ secrets.GHCR_TOKEN != '' }}
        uses: docker/login-action@v3
        with:
          registry: ghcr.io
          username: ${{ secrets.GHCR_USER }}
          password: ${{ secrets.GHCR_TOKEN }}

      - name: Build and push Docker image
        if: ${{ secrets.GHCR_TOKEN != '' }}
        uses: docker/build-push-action@v6
        with:
          context: .
          push: ${{ github.ref == 'refs/heads/main' }}
          tags: |
            ghcr.io/komluk/${{ github.event.repository.name }}:latest
            ghcr.io/komluk/${{ github.event.repository.name }}:${{ github.sha }}
          build-args: BASE_PATH=/app/{{PROJECT_ID}}/
          cache-from: type=registry,ref=ghcr.io/komluk/${{ github.event.repository.name }}:latest
          cache-to: type=inline

  deploy:
    name: Deploy to Coolify
    needs: build
    if: github.ref == 'refs/heads/main'
    runs-on: [self-hosted, deploy]
    timeout-minutes: 10

    steps:
      - name: Trigger Coolify deployment
        if: ${{ vars.COOLIFY_WEBHOOK_URL != '' }}
        run: |
          RESPONSE=$(curl -sf -X POST \
            "${{ vars.COOLIFY_WEBHOOK_URL }}" \
            -H "Authorization: Bearer ${{ secrets.COOLIFY_TOKEN }}" \
            -H "Content-Type: application/json" \
            --max-time 30)
          echo "Coolify response: ${RESPONSE}"

      - name: Wait for deployment health
        if: ${{ vars.COOLIFY_WEBHOOK_URL != '' }}
        run: |
          echo "Waiting 30s for container startup..."
          sleep 30
          echo "Deployment triggered successfully"
